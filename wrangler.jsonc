{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloud-agent",
  "main": "src/server.ts",
  "compatibility_date": "2026-06-05",
  "compatibility_flags": ["nodejs_compat"],
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "instance_type": "standard-1",
      "max_instances": 5
    }
  ],
  "assets": {
    "directory": "./public",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*", "/oauth/*", "/api/*"]
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "TaskAgent",
        "name": "TaskAgent"
      },
      {
        "class_name": "TaskRegistry",
        "name": "TaskRegistry"
      },
      {
        "class_name": "Sandbox",
        "name": "Sandbox"
      }
    ]
  },
  "r2_buckets": [
    {
      "binding": "BACKUP_BUCKET",
      "bucket_name": "cloud-agent-backups"
    }
  ],
  "migrations": [
    {
      "new_sqlite_classes": ["TaskAgent", "Sandbox"],
      "tag": "v1"
    },
    {
      "new_sqlite_classes": ["TaskRegistry"],
      "tag": "v2"
    }
  ],
  "vars": {
    "BACKUP_BUCKET_NAME": "cloud-agent-backups",
    "CLOUDFLARE_ACCOUNT_ID": "42858c96007b726ffb88ee5e50eed404",
    "DEEPSEEK_MODEL": "deepseek-v4-pro"
  }
}
