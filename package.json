{
  "name": "cloud-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Single-user autonomous Cloudflare Sandbox agent",
  "keywords": [
    "agents",
    "ai",
    "cloudflare"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "start": "vite dev",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "types": "wrangler types env.d.ts --include-runtime false",
    "format": "oxfmt --write src/ package.json wrangler.jsonc tsconfig.json vite.config.ts",
    "lint": "oxlint src/",
    "check": "oxfmt --check src/ package.json wrangler.jsonc tsconfig.json vite.config.ts && oxlint src/ && tsc"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^1.0.21",
    "@cloudflare/ai-chat": "^0.8.0",
    "@cloudflare/sandbox": "^0.7.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "agents": "^0.14.0",
    "ai": "^6.0.206",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.21",
    "lucide-react": "^1.20.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "pretty-ms": "^9.3.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "shadcn": "^4.11.0",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@cloudflare/vite-plugin": "1.39.1",
    "@cloudflare/workers-types": "^4.20260602.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "4.96.0"
  }
}
